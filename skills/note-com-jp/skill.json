{
  "id": "note-com-jp",
  "title": "note AI（日本語）",
  "description": "note.com で過去24時間に人気の AI 技術記事を、中文要約＋やさしい日本語(N3–N2)で配信。",
  "enabled": true,
  "ai": {
    "mode": "auto",
    "provider": "deepseek",
    "outputLanguage": "zh-CN"
  },
  "schedule": {
    "cron": "0 22 * * *",
    "timezone": "Asia/Tokyo",
    "lookbackHours": 24
  },
  "output": {
    "navSection": "Japanese",
    "icon": "🇯🇵"
  },
  "env": {
    "required": []
  },
  "dedup": {
    "enabled": true,
    "keyField": "id"
  },
  "digest": {
    "maxItems": 5
  },
  "notification": {
    "channels": [
      "discord"
    ]
  }
}
