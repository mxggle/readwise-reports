{
  "id": "hn",
  "title": "HackerNews",
  "description": "Daily digest of top tech blog articles aggregated from 90 RSS feeds (curated 2025 list).",
  "enabled": true,
  "ai": {
    "mode": "auto",
    "provider": "gemini",
    "outputLanguage": "en-US"
  },
  "schedule": {
    "cron": "0 22 * * *",
    "timezone": "Asia/Tokyo",
    "lookbackHours": 48
  },
  "output": {
    "navSection": "Tech",
    "icon": "📰"
  },
  "digest": {
    "maxItems": 15
  },
  "notification": {
    "channels": ["discord"]
  }
}
