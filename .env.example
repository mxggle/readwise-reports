# Readwise / Reader
# Preferred for API mode. Get one from https://readwise.io/access_token
READWISE_TOKEN=

# Optional. If READWISE_TOKEN is empty, scripts try the local `readwise` CLI.
READWISE_USE_CLI=true

# AI summary provider, optional. If omitted, system uses deterministic local summaries.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Discord. Use webhook for summary-only notification.
DISCORD_WEBHOOK_URL=

# Public site URL, e.g. https://<user>.github.io/readwise-reports
PUBLIC_SITE_URL=

# Default timezone for publish-daily date formatting.
# Per-skill lookback / schedule lives in each skills/<id>/skill.json manifest.
REPORT_TIMEZONE=Asia/Tokyo
